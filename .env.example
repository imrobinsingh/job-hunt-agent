# Notion Integration
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_your_integration_secret_here

# The Notion page where your Job Tracker database will live
# Get from the page URL: notion.so/Your-Page-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_PAGE_ID=your_page_id_here

# Auto-filled by setup.py — leave blank initially
NOTION_DATABASE_ID=

# Free Gemini API key
# Get from: https://aistudio.google.com/app/apikey (no credit card needed)
GEMINI_API_KEY=your_gemini_api_key_here
